{
  "name": "cypress-colmeia-qa",
  "version": "1.0.0",
  "description": "Suite de testes automatizados para o sistema Colmeia (teste prático QA)",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "test:login": "cypress run --spec 'cypress/testes/login/**/*.cy.js'",
    "test:ui": "cypress run --spec 'cypress/testes/ui/**/*.cy.js'",
    "test:headed": "cypress run --headed",
    "test:chrome": "cypress run --browser chrome"
  },
  "devDependencies": {
    "cypress": "^13.15.0"
  },
  "author": "Victor",
  "license": "MIT"
}
